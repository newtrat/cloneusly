# Database (Prisma Postgres)
DATABASE_URL=
DIRECT_URL=

# Test database (separate from development)
TEST_DATABASE_URL=

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Company configuration
COMPANY_TIME_ZONE=America/Los_Angeles

# Vercel Cron (production only)
# CRON_SECRET=

# Test mode
ENABLE_TEST_TOPUPS=true
MAX_TEST_TOPUP_POINTS=1000

# GIF allowlist (comma-separated hosts)
ALLOWED_GIF_HOSTS=media.giphy.com,media.tenor.com

# Optional: enables live Giphy search in the in-app GIF picker.
# Without it, the picker falls back to a curated set of GIFs.
GIPHY_API_KEY=

# Seed script (development only)
SEED_USER_PASSWORD=
